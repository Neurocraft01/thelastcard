# =============================================================================
# The Last Card — Example Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to version control.

# =============================================================================
# Django Core
# =============================================================================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-minimum-50-characters-required
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF Trusted Origins (comma-separated, include scheme)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Site Settings
SITE_NAME=The Last Card
SITE_URL=http://localhost:8000


# =============================================================================
# Database — Supabase PostgreSQL (Session Pooler, IPv4-safe)
# =============================================================================
# Leave empty to use SQLite for local development.
#
# Production: use the Supabase Session Pooler (port 6543) — works from any
# network including Render's free tier (IPv4 only).
#
# Get your connection string from:
#   Supabase Dashboard → Settings → Database → Connection string → URI
#   Choose the "Session mode" pooler URL (port 6543).
#
# Format:
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

DATABASE_URL=postgresql://postgres.yourprojectref:yourpassword@aws-0-ap-south-1.pooler.supabase.com:6543/postgres


# =============================================================================
# Cloudflare R2 Object Storage (S3-Compatible)
# =============================================================================
# Enables persistent media file storage via Cloudflare R2.
# Set USE_R2_STORAGE=False to store uploads locally (development only).
#
# Credentials from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
#   Create a token with "Object Read & Write" on your bucket.
#
# R2_CUSTOM_DOMAIN (optional): e.g. media.thelastcard.in
#   Set up in Cloudflare R2 → your bucket → Settings → Custom Domains.
#   If omitted, the r2.dev public bucket URL is used
#   (requires Public Access enabled on the bucket in R2 dashboard).

USE_R2_STORAGE=False
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=thelastcard
# R2_CUSTOM_DOMAIN=media.thelastcard.in


# =============================================================================
# Email — Gmail SMTP
# =============================================================================
# Use an App Password (not your regular account password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=The Last Card <noreply@yourdomain.com>


# =============================================================================
# CORS Settings
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000


# =============================================================================
# Razorpay Payment Gateway
# =============================================================================
# Get keys from: https://dashboard.razorpay.com/app/keys
# Test keys start with rzp_test_, live keys with rzp_live_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

